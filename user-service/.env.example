# Copy to .env and fill in real values. .env is git-ignored.

# --- Django core ------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# --- Database ---------------------------------------------------------------
# Inside docker-compose the POSTGRES_HOST below is overridden to "user-db"
# by the compose service env. When running on the host venv, leave it as
# "localhost" (and either run `docker compose up -d user-db` or a local Postgres).
POSTGRES_DB=user_db
POSTGRES_USER=user_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Server -----------------------------------------------------------------
# In-container bind port. Must match the ports mapping in docker-compose.yml
# ("8003:8003") and the runserver / gunicorn call in entrypoint.sh.
PORT=8003
# development -> runserver (auto-reload). production -> gunicorn (3 workers).
# Leave as production in the container; set to development on the host venv.
ENVIRONMENT=development
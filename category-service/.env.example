# Copy to .env and fill in real values. .env is git-ignored.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# Database (category-db in docker-compose)
POSTGRES_DB=category_db
POSTGRES_USER=category_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=category-db
POSTGRES_PORT=5432

# Server mode. development -> runserver (auto-reload). production -> gunicorn.
# Leave as production in the container; set to development only on the host venv.
ENVIRONMENT=production

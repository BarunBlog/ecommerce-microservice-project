# Copy to .env and fill in real values. .env is git-ignored.
# A sane dev password is provided as a default so `docker compose up` works
# out of the box. Override it in any non-local environment.

# --- Postgres (consumed by both compose + Nest) ---
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_dev_password
# `host.docker.internal` resolves to the Docker host from inside a
# container AND from a host-side Prisma on Docker Desktop / WSL2.
# The container's compose override rewrites DATABASE_URL to
# `inventory-db:5432`, so this value is only seen by host-side tools.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# --- HTTP server ---
# Port the Nest app binds to. Default is 8002 to avoid colliding with
# category-service (8000) and product-service (8001). The Dockerfile and
# compose agree on this default; change either this line OR the compose
# `ports:` mapping, not both, to keep them in sync.
PORT=8002

# --- Prisma ---
# Literal DATABASE_URL — Prisma's CLI reads it directly from `.env`
# (no shell expansion). If you change any of the POSTGRES_* parts,
# regenerate this line by hand to match.
DATABASE_URL=postgresql://inventory_user:inventory_dev_password@host.docker.internal:5432/inventory_db?schema=public

# --- RabbitMQ ---
# Platform-wide event broker owned by infra/docker-compose.yml at the
# repo root. The Nest consumer binds a durable queue to the
# `ecommerce.events` topic exchange with the routing key
# `products.event.created` so it auto-provisions an Inventory row when
# product-service announces a new product.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=ecommerce.events
# Queue name is consumer-local. Re-declared with `durable: true` on
# connect so a broker restart does not lose the binding.
RABBITMQ_QUEUE=inventory-service.products.created

# --- Runtime mode ---
# `production` -> `node dist/main.js` (default; what the container runs).
# `development` -> `nest start --watch` (host-side venv-style dev only).
ENVIRONMENT=production
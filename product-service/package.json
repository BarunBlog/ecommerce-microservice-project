    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^10.3.7",
    "@nestjs/platform-express": "^10.3.7",
    "@prisma/client": "^5.15.0",
    "amqp-connection-manager": "^5.0.0",

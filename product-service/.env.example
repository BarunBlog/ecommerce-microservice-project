# Copy to .env and fill in real values. .env is git-ignored.
# A sane dev password is provided as a default so `docker compose up` works
# out of the box. Override it in any non-local environment.

# --- Postgres (consumed by both compose + Nest) ---
POSTGRES_DB=product_db
POSTGRES_USER=product_user
POSTGRES_PASSWORD=product_dev_password
# `host.docker.internal` resolves to the Docker host from inside a
# container AND from a host-side Prisma on Docker Desktop / WSL2.
# The container's compose override rewrites DATABASE_URL to
# `product-db:5432`, so this value is only seen by host-side tools.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# --- HTTP server ---
# Port the Nest app binds to. Default is 8001 to avoid the collision with
# category-service on the same host. The Dockerfile and compose agree on
# this default; change either this line OR the compose `ports:` mapping,
# not both, to keep them in sync.
PORT=8001

# --- Prisma ---
# Literal DATABASE_URL — Prisma's CLI reads it directly from `.env`
# (no shell expansion). If you change any of the POSTGRES_* parts,
# regenerate this line by hand to match.
DATABASE_URL=postgresql://product_user:product_dev_password@host.docker.internal:5432/product_db?schema=public

# --- Cross-service HTTP ---
# category-service is reached over the shared `category-net` Docker
# network. The compose file pins this to the container alias and you
# should not need to touch it.
CATEGORY_SERVICE_BASE_URL=http://category-service:8000

# --- RabbitMQ ---
# Platform-wide event broker. Other services (notification, search, ...)
# will subscribe to the topics published here.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=ecommerce.events
RABBITMQ_QUEUE=product-service.events

# --- Runtime mode ---
# `production` -> `node dist/main.js` (default; what the container runs).
# `development` -> `nest start --watch` (host-side venv-style dev only).
ENVIRONMENT=production